<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_contract_view_form_igm_max_hours" model="ir.ui.view">
        <field name="name">hr.contract.form.igm.max.hours</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='salary']//div[@name='wage']" position="after">
                <label for="igm_max_hours_per_month"/>
                <div class="o_row mw-50">
                    <field name="igm_max_hours_per_month" class="oe_inline o_hr_narrow_field" nolabel="1"/>
                    <div class="mb-3">h / month</div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>

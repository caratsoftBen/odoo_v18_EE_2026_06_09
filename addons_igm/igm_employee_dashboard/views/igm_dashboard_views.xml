<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_redirect_igm_cron" model="ir.actions.act_window">
        <field name="name">Run Recurring Task Forecast</field>
        <field name="res_model">ir.cron</field>
        <field name="res_id" ref="igm_task_forecast.ir_cron_igm_task_forecast"/>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

    <record id="action_open_employee_hub" model="ir.actions.act_window">
        <field name="name">My Hub</field>
        <field name="res_model">igm.employee.dashboard</field>
        <field name="view_mode">form</field>
        <field name="target">main</field>
    </record>

    <record id="view_igm_employee_dashboard_form" model="ir.ui.view">
        <field name="name">igm.employee.dashboard.form</field>
        <field name="model">igm.employee.dashboard</field>
        <field name="arch" type="xml">
            <form string="Workspace Hub" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_title mb-4">
                        <h2 class="text-primary fw-bold">Operational Control Dashboard</h2>
                    </div>

                    <div class="row g-3">

                        <div class="col-12 col-md-4">
                            <button name="action_open_field_service" type="object"
                                    class="btn btn-link p-0 border-0 w-100 h-100 text-decoration-none">
                                <div class="border p-4 rounded bg-light text-center h-100 shadow-sm d-flex flex-column justify-content-center align-items-center">
                                    <h5 class="fw-bold text-uppercase text-secondary mb-3">🛠️ Field Service</h5>
                                    <field name="igm_field_service_count" readonly="1" class="fw-bold display-4 text-primary mb-2"/>
                                    <span class="text-body-secondary small">Open assignments waiting for you</span>
                                </div>
                            </button>
                        </div>

                        <div class="col-12 col-md-4">
                            <div class="border p-4 rounded bg-light h-100 shadow-sm d-flex flex-column justify-content-between">
                                <div>
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <h5 class="fw-bold text-uppercase text-secondary mb-0">🔄 Recurring Forecast</h5>
                                        <button name="%(igm_task_forecast.action_igm_task_forecast_settings)d"
                                                type="action" icon="fa-cog"
                                                class="btn btn-link p-0 text-secondary"
                                                title="Forecast settings"/>
                                    </div>
                                    <p class="text-body-secondary small mb-4">Generate the upcoming recurring tasks now.</p>
                                </div>
                                <button name="%(action_redirect_igm_cron)d"
                                        type="action"
                                        string="Run Forecast Now"
                                        class="btn btn-primary w-100 py-2"/>
                            </div>
                        </div>

                        <div class="col-12 col-md-4" groups="base.group_system">
                            <button name="%(igm_cleaning_onboarding.action_igm_cleaning_onboarding_wizard)d" type="action"
                                    class="btn btn-link p-0 border-0 w-100 h-100 text-decoration-none">
                                <div class="border p-4 rounded bg-light text-center h-100 shadow-sm d-flex flex-column justify-content-center align-items-center">
                                    <h5 class="fw-bold text-uppercase text-secondary mb-3">🧹 Onboarding</h5>
                                    <i class="fa fa-user-plus display-4 text-primary mb-2"/>
                                    <span class="text-body-secondary small">Create a new cleaning-service user</span>
                                </div>
                            </button>
                        </div>

                    </div>
                </sheet>
            </form>
        </field>
    </record>

<menuitem id="menu_igm_employee_dashboard_root" 
          name="Operations Hub" 
          sequence="5"
          action="action_open_employee_hub"
          web_icon="igm_employee_dashboard,static/description/icon.png"/>

</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="igm_fsm_photo_wizard_form" model="ir.ui.view">
        <field name="name">igm.fsm.photo.wizard.form</field>
        <field name="model">igm.fsm.photo.wizard</field>
        <field name="arch" type="xml">
            <form string="Foto">
                <group>
                    <field name="task_id" invisible="1"/>
                    <field name="image" widget="image"/>
                    <field name="note"/>
                </group>
                <footer>
                    <button name="action_post" type="object" string="Speichern" class="btn-primary"/>
                    <button string="Abbrechen" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_igm_fsm_photo_wizard" model="ir.actions.act_window">
        <field name="name">Foto</field>
        <field name="res_model">igm.fsm.photo.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

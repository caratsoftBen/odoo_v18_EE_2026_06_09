<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_redirect_igm_cron" model="ir.actions.act_window">
        <field name="name">Scheduled Action Control</field>
        <field name="res_model">ir.cron</field>
        <field name="view_mode">form</field>
        <field name="domain">[('name', '=', '[IGM] Generate Recurring Task Forecast')]</field>
    </record>

    <record id="action_open_employee_hub" model="ir.actions.act_window">
        <field name="name">My Hub</field>
        <field name="res_model">x.employee.dashboard</field>
        <field name="view_mode">form</field>
        <field name="target">main</field>
    </record>

    <record id="view_x_employee_dashboard_form" model="ir.ui.view">
        <field name="name">x.employee.dashboard.form</field>
        <field name="model">x.employee.dashboard</field>
        <field name="arch" type="xml">
            <form string="Workspace Hub" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_title mb-4">
                        <h2 class="text-primary fw-bold">Operational Control Dashboard</h2>
                    </div>

                    <div class="row g-3">

                        <div class="col-12 col-md-4">
                            <div class="border p-4 rounded bg-light text-center h-100 shadow-sm d-flex flex-column justify-content-center align-items-center">
                                <h5 class="fw-bold text-uppercase text-secondary mb-3">🛠️ Field Service</h5>
                                <field name="x_field_service_count" readonly="1" class="fw-bold display-4 text-primary mb-2"/>
                                <span class="text-body-secondary small">Open assignments waiting for you</span>
                            </div>
                        </div>

                        <div class="col-12 col-md-4">
                            <div class="border p-4 rounded bg-light h-100 shadow-sm d-flex flex-column justify-content-between">
                                <div>
                                    <h5 class="fw-bold text-uppercase text-secondary mb-3">⚙️ System Actions</h5>
                                    <p class="text-body-secondary small mb-4">Execute or adjust the background task scheduling algorithms manually:</p>
                                </div>
                                <button name="%(action_redirect_igm_cron)d"
                                        type="action"
                                        string="Open Forecast Settings"
                                        class="btn btn-primary w-100 py-2"/>
                            </div>
                        </div>

                        <div class="col-12 col-md-4">
                            <div class="border p-4 rounded bg-light h-100 shadow-sm opacity-75 d-flex flex-column justify-content-center align-items-center">
                                <h5 class="fw-bold text-uppercase text-secondary mb-3">📦 Future Modules</h5>
                                <p class="text-body-secondary small text-center m-0">
                                    <em>[ Placeholder for future custom x_app integration ]</em>
                                </p>
                            </div>
                        </div>

                    </div>
                </sheet>
            </form>
        </field>
    </record>

<menuitem id="menu_x_employee_dashboard_root" 
          name="Operations Hub" 
          sequence="5"
          action="action_open_employee_hub"
          web_icon="x_employee_dashboard,static/description/icon.png"/>

</odoo>
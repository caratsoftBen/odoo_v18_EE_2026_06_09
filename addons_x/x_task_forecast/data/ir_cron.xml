<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- noupdate: the run frequency is meant to be tuned in the standard
         Scheduled Actions UI; module upgrades must not reset it. -->
    <data noupdate="1">
        <record id="ir_cron_x_task_forecast" model="ir.cron">
            <field name="name">[IGM] Generate Recurring Task Forecast</field>
            <field name="model_id" ref="project.model_project_task_recurrence"/>
            <field name="state">code</field>
            <field name="code">model._cron_generate_forecast()</field>
            <field name="interval_number">2</field>
            <field name="interval_type">weeks</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
